{:paths ["src" "test"]

 ;; Fireworks is a real dependency because this project's code calls `?`.
 :deps {io.github.paintparty/fireworks {:mvn/version "0.20.0"}}

 :tasks
 ;; Live Code runs `bb dev`. The task calls `load-file` on the Fireworks
 ;; watcher, which the extension seeds into .fireworks/bb/watch.clj on first
 ;; launch (and never overwrites). That is the opt-in: bb is only offered when
 ;; a task loads this watcher.
 {dev {:doc  "Live Code watcher: reload on save, paint `?` results inline."
       :task (load-file ".fireworks/bb/watch.clj")}}}
