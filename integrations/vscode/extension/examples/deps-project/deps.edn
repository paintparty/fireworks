{:paths ["src"]

 ;; Fireworks is a real dependency because this project's code calls `?`.
 :deps {org.clojure/clojure            {:mvn/version "1.12.0"}
        io.github.paintparty/fireworks {:mvn/version "0.20.0"}}

 :aliases
 ;; Live Code runs `clojure -M:test-refresh`. test-refresh watches src/ +
 ;; test/, reloads on save (re-running top-level `?` forms) and runs tests.
 ;; Scoped to this alias so the dev tool stays out of the project's normal
 ;; dependency set.
 {:test-refresh
  {:extra-paths ["test"]
   :extra-deps  {com.jakemccrary/test-refresh {:mvn/version "0.26.0"}}
   :main-opts   ["-m" "com.jakemccrary.test-refresh"]}}}
